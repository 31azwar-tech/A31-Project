rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Setiap user hanya bisa membaca & menulis dokumen board miliknya sendiri.
    // Dokumen disimpan di koleksi "boards" dengan ID = UID user.
    // (Skema ini SAMA dengan A31-PM lama, jadi data lama langsung terbaca.)
    match /boards/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Tolak semua akses lain secara default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
